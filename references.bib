@inreference{2004HallamTornado2026,
	title = {2004 Hallam tornado},
	rights = {Creative Commons Attribution-{ShareAlike} License},
	url = {https://en.wikipedia.org/w/index.php?title=2004_Hallam_tornado&oldid=1345145456},
	abstract = {The 2004 Hallam tornado was a long-tracked and extremely large F4 tornado that tore through multiple counties in southeast Nebraska during the evening hours of May 22, 2004. The tornado, part of a tornado outbreak sequence, damaged many towns along its path, but its most destructive effect occurred at the town of Hallam. The tornado is recognized by {NOAA} as the second-largest tornado on record, peaking at 2.5 miles (4.0 km) wide at Hallam, behind only the 2013 El Reno tornado, the tornado holds the record as the largest tornado in Nebraska's history.},
