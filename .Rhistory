Historically, tornadoes occur in the Central United States, nicknamed "Tornado Alley".
sharknado_count <- 2
total_observations <- 31345
# Perform a one-sample proportion test
# correct = FALSE provides the standard 'textbook' interval
# conf.level = 0.95 gives us the 95% certainty range
proportion_results <- prop.test(x = sharknado_count,
n = total_observations,
conf.level = 0.95,
correct = FALSE)
# Display the 95% Confidence Interval
proportion_results$conf.int
