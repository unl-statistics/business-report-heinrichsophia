plot_coastal_tornadoes <- function(coast_data, region_name) {
# 1. Get US States map for background
us_states <- states(cb = TRUE, resolution = "20m") %>%
filter(!STUSPS %in% c("AK", "HI", "PR", "GU")) %>%
st_transform(crs = 5070)
# 2. Filter for tornadoes starting at the specific coast
# We filter for 'Moving Inland' to show the "Sharknado" potential paths
plot_data <- coast_data %>%
filter(Start_coast == region_name, path_movement == "Moving Inland")
# 3. Create the Plot
ggplot() +
# Draw State Borders
geom_sf(data = us_states, fill = "whitesmoke", color = "gray80", size = 0.2) +
# Draw Tornado Path Lines
geom_segment(data = plot_data,
aes(x = BEGIN_LON, y = BEGIN_LAT, xend = END_LON, yend = END_LAT, color = shark_potential),
alpha = 0.6, size = 0.5) +
# Draw Starting Points (Touchdown)
geom_point(data = plot_data, aes(x = BEGIN_LON, y = BEGIN_LAT), color = "darkblue", size = 1, alpha = 0.8) +
# Draw Ending Points (Lift-off)
geom_point(data = plot_data, aes(x = END_LON, y = END_LAT), color = "darkred", size = 1, alpha = 0.8) +
# Styling
scale_color_manual(values = c("High Potential" = "firebrick", "Low Potential" = "steelblue")) +
theme_void() +
labs(title = paste(region_name, "Coastal Tornado Trajectories"),
subtitle = "Blue dots: Touchdown | Red dots: Lift-off",
color = "Shark-Lifting Potential") +
theme(plot.title = element_text(face = "bold", size = 16),
legend.position = "bottom")
}
