library(ggplot2)
library(sf)
library(tigris)
library(dplyr)
# Function to generate a map for a specific coast
plot_coastal_tornadoes <- function(coast_data, region_name) {
# 1. Get US States map for background
us_states <- states(cb = TRUE, resolution = "20m") %>%
filter(!STUSPS %in% c("AK", "HI", "PR", "GU")) %>%
st_transform(crs = 5070)
# 2. Filter for tornadoes starting at the specific coast
# We filter for 'Moving Inland' to show the "Sharknado" potential paths
plot_data <- coast_data %>%
filter(Start_coast == region_name, path_movement == "Moving Inland")
# 3. Create the Plot
ggplot() +
# Draw State Borders
geom_sf(data = us_states, fill = "whitesmoke", color = "gray80", size = 0.2) +
# Draw Tornado Path Lines
geom_segment(data = plot_data,
aes(x = BEGIN_LON, y = BEGIN_LAT, xend = END_LON, yend = END_LAT, color = shark_potential),
alpha = 0.6, size = 0.5) +
# Draw Starting Points (Touchdown)
geom_point(data = plot_data, aes(x = BEGIN_LON, y = BEGIN_LAT), color = "darkblue", size = 1, alpha = 0.8) +
# Draw Ending Points (Lift-off)
geom_point(data = plot_data, aes(x = END_LON, y = END_LAT), color = "darkred", size = 1, alpha = 0.8) +
# Styling
scale_color_manual(values = c("High Potential" = "firebrick", "Low Potential" = "steelblue")) +
theme_void() +
labs(title = paste(region_name, "Coastal Tornado Trajectories"),
subtitle = "Blue dots: Touchdown | Red dots: Lift-off",
color = "Shark-Lifting Potential") +
theme(plot.title = element_text(face = "bold", size = 16),
legend.position = "bottom")
}
# Generate the three visuals
# Note: Ensure 'final_glued_events' is in your environment
plot_atlantic <- plot_coastal_tornadoes(final_glued_events, "Atlantic")
View(final_glued_events)
View(final_glued_events.filter(Start_location="Coastal"))
final_glued_events %>%
filter(Start_location == "Coastal") %>%
View()
library(gt)
library(tidyverse)
# 1. Manually recreate the summary data for the presentation file
shark_results_tbl <- tibble(
path_movement = c("Moving Coastal", "Moving Coastal", "Moving Inland", "Moving Inland", "Other Path", "Other Path"),
shark_lifting_potential = c("High Potential", "Low Potential", "High Potential", "Low Potential", "High Potential", "Low Potential"),
event_count = c(2, 60, 2, 71, 3799, 27411),
percentage = c(0.0323, 0.968, 0.0274, 0.973, 0.122, 0.878)
)
# 2. Create the professional gt table
shark_results_tbl %>%
gt(groupname_col = "path_movement") %>%
tab_header(
title = "Tornado Path Trajectory and Shark-Lifting Potential",
subtitle = "75-Year Longitudinal Study (1950-2025)"
) %>%
cols_label(
shark_lifting_potential = "Potential Category",
event_count = "Event Count",
percentage = "Proportion"
) %>%
fmt_percent(
columns = percentage,
decimals = 1
) %>%
fmt_number(
columns = event_count,
decimals = 0
) %>%
tab_style(
style = cell_text(weight = "bold"),
locations = cells_row_groups()
) %>%
cols_align(
align = "center",
columns = everything()
) %>%
tab_options(
table.width = pct(80),
heading.title.font.size = px(20)
)
final_glued_events %>%
filter(shark_lifting_potential == "High Potential") %>%
filter(path_movement == "Moving Inland") %>%
View()
# RESULTS - summary statistics
path_summary <- final_glued_events %>%
group_by(path_movement, shark_lifting_potential) %>%
summarize(event_count = n(), .groups = "drop") %>%
# Calculate percentages to see the relative risk
group_by(path_movement) %>%
mutate(percentage = (event_count / sum(event_count)))
final_glued_events <- tornado_segments_with_keys %>%
group_by(master_id) %>%
summarize(
YEAR = first(YEAR),
MONTH_NAME = first(MONTH_NAME),
# columns for beginning state and ending states
Beginning_State = first(STATE),
End_State       = last(STATE),
# Start/end location and coast (if applicable)
Start_location = first(Start_location),
Start_coast    = first(Start_coast),
End_location   = last(End_location),
End_coast      = last(End_coast),
# Use maximum tornado intensity across segments
TOR_F_SCALE_MAX = max(TOR_F_SCALE, na.rm = TRUE),
# sum damage across segments
Total_Damage = sum(parse_number(DAMAGE_PROPERTY), na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
# Classify path movement as "Moving [to the] Inland", "Moving [to the] Coastal", or "Other Path"
path_movement = case_when(
Start_location == "Coastal" & End_location == "Inland" ~ "Moving Inland",
Start_location == "Inland"  & End_location == "Coastal" ~ "Moving Coastal",
TRUE ~ "Other Path"
),
# Intensity Flag
shark_lifting_potential = ifelse(TOR_F_SCALE_MAX %in% c("F3", "F4", "F5", "EF3","EF4", "EF5"),
"High Potential", "Low Potential")
)
